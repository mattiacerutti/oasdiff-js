{
  "name": "@oasdiff-js/oasdiff-js",
  "version": "0.0.1",
  "oasdiffVersion": "1.15.0",
  "description": "TypeScript wrapper for the oasdiff CLI",
  "author": "mattiacerutti",
  "license": "Apache-2.0",
  "homepage": "https://github.com/mattiacerutti/oasdiff-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattiacerutti/oasdiff-js.git"
  },
  "bugs": {
    "url": "https://github.com/mattiacerutti/oasdiff-js/issues"
  },
  "keywords": [
    "oasdiff",
    "openapi",
    "swagger",
    "diff",
    "breaking-changes",
    "api",
    "cli"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "prepublishOnly": "npm run build",
    "postinstall": "node ./npm-install/postinstall.js",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --check ./src ./tests",
    "test": "vitest run"
  },
  "bin": {
    "oasdiff": "bin/oasdiff.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin/oasdiff.js",
    "bin/LICENSE",
    "npm-install"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "https-proxy-agent": "^7.0.6",
    "node-fetch": "^3.3.2",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "prettier": "^3.6.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
