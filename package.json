{
  "name": "@oasdiff-js/oasdiff-js",
  "version": "0.0.1",
  "description": "TypeScript wrapper for the oasdiff CLI",
  "author": "mattiacerutti",
  "license": "Apache-2.0",
  "homepage": "https://github.com/oasdiff/oasdiff",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "node ./npm-install/postinstall.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --check ./src"
  },
  "bin": {
    "oasdiff": "bin/oasdiff.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "npm-install"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "https-proxy-agent": "^7.0.6",
    "node-fetch": "^3.3.2",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "eslint": "^9.39.2",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3"
  }
}
