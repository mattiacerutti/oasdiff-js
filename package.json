{
  "name": "@oasdiff-js/oasdiff-js",
  "version": "0.0.1",
  "oasdiffVersion": "1.15.0",
  "description": "TypeScript/JavaScript wrapper for the oasdiff CLI",
  "author": {
    "name": "Mattia Cerutti",
    "url": "https://github.com/mattiacerutti"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/mattiacerutti/oasdiff-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattiacerutti/oasdiff-js.git"
  },
  "bugs": {
    "url": "https://github.com/mattiacerutti/oasdiff-js/issues"
  },
  "keywords": [
    "oasdiff",
    "openapi",
    "swagger",
    "openapi-diff",
    "api-diff",
    "breaking-changes",
    "changelog",
    "api",
    "openapi",
    "cli",
    "typescript",
    "javascript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --check ./src ./tests",
    "test": "vitest run",
    "sync-binaries": "bun scripts/sync-binaries.ts"
  },
  "bin": {
    "oasdiff": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "@oasdiff-js/oasdiff-darwin-arm64": "1.15.0",
    "@oasdiff-js/oasdiff-darwin-x64": "1.15.0",
    "@oasdiff-js/oasdiff-linux-arm64": "1.15.0",
    "@oasdiff-js/oasdiff-linux-x64": "1.15.0",
    "@oasdiff-js/oasdiff-windows-arm64": "1.15.0",
    "@oasdiff-js/oasdiff-windows-x64": "1.15.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "prettier": "^3.6.2",
    "tar": "^7.5.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@types/node": "^25.6.0"
  }
}
